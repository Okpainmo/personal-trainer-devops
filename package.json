{
  "name": "personal-trainer-devops-documentation",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "description": "Centralized DevOps documentation for the Personal Trainer project.",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "security:forbidden-patterns": "bash scripts/forbidden-pattern-scan.sh",
    "commitlint": "commitlint --edit"
  },
  "lint-staged": {
    "*.md": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
